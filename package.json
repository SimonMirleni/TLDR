{
  "name": "readlater-digest",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "dev:extension": "pnpm --filter @rld/extension dev",
    "dev:backend": "pnpm --filter @rld/backend dev",
    "db:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_REF --schema public > db/generated.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "typescript": "^5.6.3"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "0.25.12"
    }
  }
}
