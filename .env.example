# --- Supabase (project ref + anon key from the dashboard) ---
SUPABASE_PROJECT_REF=
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=

# --- Backend only ---
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...
# Chrome extension origin allowed to call the backend (set after first load of the unpacked extension)
ALLOWED_EXTENSION_ORIGIN=chrome-extension://<extension_id>
# Optional: port for local dev
PORT=8787

# --- Extension (consumed at build time by WXT via import.meta.env) ---
WXT_SUPABASE_URL=https://<ref>.supabase.co
WXT_SUPABASE_ANON_KEY=
WXT_BACKEND_URL=https://<railway-app>.up.railway.app
# Google OAuth client ID (type: Chrome Extension) from Google Cloud Console
WXT_GOOGLE_CLIENT_ID=<client-id>.apps.googleusercontent.com
